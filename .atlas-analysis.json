  "keyFeatures": [
    "Unified V5 REST client covering all Bybit API categories (spot, linear, inverse, option)",
    "WebSocket client with automatic authentication, heartbeats, and reconnect-then-resubscribe",
    "Promise-driven WebsocketAPIClient for submitting orders over WebSocket like a REST API",
    "Higher API rate limits (400 req/s) automatically applied for all SDK users",
    "Full TypeScript support with thorough request and response type declarations",
    "HMAC and RSA authentication auto-detection",
    "Multi-region support: global, bytick, EU, NL, TK, KZ, HK, GE, UAE domains",
    "Browser support via webpack bundle or direct import with stream-browserify",
    "LLM/AI integration via bundled llms.txt file",
    "Proxy support via axios integration"
  ],
  "publicApiSurface": [
    "RestClientV5",
    "WebsocketClient",
    "WebsocketAPIClient",
    "SpotClientV3",
    "WS_KEY_MAP",
    "DefaultLogger",
    "API_ERROR_CODE",
